# ─────────────────────────────────────────────────────────────
#  Training Assistant — Backend Environment Variables
#  Copy this file to ".env" and fill in real values.
#  NEVER commit the real .env file to git.
# ─────────────────────────────────────────────────────────────

# --- Server ---
PORT=5000
NODE_ENV=development

# Public URL of this backend (used for OAuth callbacks)
SERVER_URL=http://localhost:5000

# Public URL of the React frontend (used for CORS + redirects)
CLIENT_URL=http://localhost:5173

# --- Database (MongoDB Atlas) ---
# Get this from Atlas > Connect > Drivers. Replace <password> and DB name.
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/training_assistant?retryWrites=true&w=majority

# --- JWT / Sessions ---
# Generate strong random strings, e.g. in Node:
#   require('crypto').randomBytes(48).toString('hex')
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d
# Lifetime (days) for the "remember me" cookie
COOKIE_MAX_AGE_DAYS=7

# --- Google OAuth 2.0 ---
# From Google Cloud Console > APIs & Services > Credentials
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
# Must EXACTLY match the redirect URI registered in Google Cloud:
GOOGLE_CALLBACK_URL=http://localhost:5000/auth/google/callback

# --- Gemini (AI Coach, via Google's OpenAI-compatible endpoint) ---
# From https://aistudio.google.com/app/apikey  (generous free tier)
GEMINI_API_KEY=AIxxxxxxxxxxxxxxxxxxxx
# Default is gemini-2.5-flash. Try gemini-2.5-flash-lite (cheaper) if you hit
# free-tier quota limits on a specific model.
GEMINI_MODEL=gemini-2.5-flash
# Only change if Google moves the endpoint:
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
